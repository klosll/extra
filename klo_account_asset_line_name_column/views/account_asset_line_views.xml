<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="klo_account_asset_line_name_column" model="ir.ui.view">
        <field name="name">klo.account.asset.line.name.column</field>
        <field name="model">account.asset.line</field>
        <field name="inherit_id" ref="account_asset_line_menu.account_asset_line_view_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='asset_id']" position="before">
                <field name="name" readonly="1" optional="show" />
            </xpath>
            <xpath expr="//field[@name='asset_id']" position="after">
                <field name="analytic_account_name" optional="show" />
            </xpath>
        </field>
    </record>
</odoo>
