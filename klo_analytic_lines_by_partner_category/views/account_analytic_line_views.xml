<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Herencia de la vista de búsqueda de Apuntes Analíticos para añadir filtro por categoría de contacto -->
    <record id="view_account_analytic_line_filter_partner_category" model="ir.ui.view">
        <field name="name">account.analytic.line.select.partner.category</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_line_filter"/>
        <field name="arch" type="xml">
            <!-- Añadir campo de búsqueda por categoría del contacto junto al campo partner_id -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="partner_category_ids" string="Categoría del Contacto"/>
            </xpath>
        </field>
    </record>
</odoo>

