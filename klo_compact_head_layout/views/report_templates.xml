<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Definir el nuevo layout compacto -->
    <template id="klo_external_layout_compact" inherit_id="web.external_layout_standard">
        <xpath expr="//div[@t-attf-class='header o_company_#{company.id}_layout']" position="replace">
            <t t-set="font_size" t-value="request.env['ir.config_parameter'].sudo().get_param('klo.report_layout_small_font_header', '12')"/>

            <!-- El logo y la dirección de nuestra empresa se coge del texto de configuración del documento por defecto -->
            <div t-attf-class="header o_company_#{company.id}_layout">
                <div class="row" style="margin-bottom: 5px;">
                    <div class=" w-50 ms-3" name="company_logo_address">
                        <div style="line-height: 1.1;" name="company_logo">
                            <img t-if="company.logo"
                                 t-att-src="image_data_uri(company.logo)"
                                 alt="Logo"
                                 style="max-height: 100px;"/>
                        </div>

                        <ul class="list-unstyled" name="company_address_list">
                            <li t-if="company.is_company_details_empty">
                                <span t-field="company.partner_id" t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'>
                                    <div class="bg-light border-1 rounded h-100 d-flex flex-column align-items-center justify-content-center p-4 w-100 opacity-75 text-muted text-center">
                                        <strong>Company address block</strong>
                                        <div>Contains the company address.</div>
                                    </div>
                                </span>
                            </li>
                            <li t-else="">
                                <span t-field="company.company_details">
                                    <div class="bg-light border-1 rounded h-100 d-flex flex-column align-items-center justify-content-center p-4 w-100 opacity-75 text-muted text-center">
                                        <strong>Company details block</strong>
                                        <div>Contains the company details.</div>
                                    </div>
                                </span>
                            </li>
                            <li t-if="not forced_vat"/>
                            <li t-else="">
                                <t t-esc="company.country_id.vat_label or 'Tax ID'">Tax ID</t>:
                                <span t-esc="forced_vat">US12345671</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Dirección de entrega (si existe). Solo lo imprime si es Pedido/presupuesto o Factura
                    Si se trata de Entrega (albarán) entonces sí imprime la dirección de entrega -->
                    <t t-if="o">
                        <t t-set="o_model" t-value="o._name"/>
                        <!-- Calcular si hay dirección de entrega para ajustar el ancho del bloque cliente -->
                        <t t-set="show_shipping" t-value="(o_model in ['sale.order', 'account.move'] and bool(o.partner_shipping_id) and o.partner_shipping_id != o.partner_id) or o_model == 'stock.picking'"/>

                        <!-- Bloque dirección de entrega: pedidos/facturas con dirección diferente -->
                        <t t-if="o_model in ['sale.order', 'account.move'] and o.partner_shipping_id and (o.partner_shipping_id != o.partner_id)">
                            <div class="col-3" style="margin-bottom: 5px; font-size: {{font_size}}px; word-wrap: break-word; overflow-wrap: break-word;">
                                <strong>Dirección de entrega:</strong><br/>
                                <div t-esc="o.partner_shipping_id.name" style="word-break: break-word;"/>
                                <t t-if="o.partner_shipping_id.comercial">(<span t-esc="o.partner_shipping_id.comercial"/>)<br/></t>
                                <span>CIF/NIF: </span><t t-esc="o.partner_shipping_id.vat"/><br/>
                                <t t-if="o.partner_shipping_id.street"><span t-esc="o.partner_shipping_id.street"/><br/></t>
                                <t t-esc="o.partner_shipping_id.zip"/> <t t-esc="o.partner_shipping_id.city"/>
                                <t t-if="o.partner_shipping_id.country_id"><br/><t t-esc="o.partner_shipping_id.country_id.name"/></t>
                                <t t-if="o.partner_shipping_id.phone"><br/><span>Tfno.: </span><t t-esc="o.partner_shipping_id.phone"/></t>
                                <t t-if="o.partner_shipping_id.email"><br/><span>e-mail: </span><t t-esc="o.partner_shipping_id.email"/></t>
                            </div>
                        </t>
                        <!-- Bloque dirección de entrega: albaranes -->
                        <t t-if="o_model == 'stock.picking'">
                            <div class="col-3" style="margin-bottom: 5px; font-size: {{font_size}}px; word-wrap: break-word; overflow-wrap: break-word;">
                                <strong>Dirección de entrega:</strong><br/>
                                <div t-esc="o.partner_id.name" style="word-break: break-word;"/>
                                <t t-if="o.partner_id.comercial">(<span t-esc="o.partner_id.comercial"/>)<br/></t>
                                <span>CIF/NIF: </span><t t-esc="o.partner_id.vat"/><br/>
                                <t t-if="o.partner_id.street"><span t-esc="o.partner_id.street"/><br/></t>
                                <t t-esc="o.partner_id.zip"/> <t t-esc="o.partner_id.city"/>
                                <t t-if="o.partner_id.country_id"><br/><t t-esc="o.partner_id.country_id.name"/></t>
                                <t t-if="o.partner_id.phone"><br/><span>Tfno.: </span><t t-esc="o.partner_id.phone"/></t>
                                <t t-if="o.partner_id.email"><br/><span>e-mail: </span><t t-esc="o.partner_id.email"/></t>
                            </div>
                        </t>

                        <!-- Dirección del cliente:
                             col-3 cuando hay dirección de entrega (comparte espacio con ella)
                             col-6 cuando NO hay dirección de entrega (se amplía hacia la derecha) -->
                        <div t-attf-class="#{'col-3' if show_shipping else 'col-6'}" style="margin-bottom: 5px; font-size: {{font_size}}px; word-wrap: break-word; overflow-wrap: break-word;">
                            <!-- Caso específico: account.payment.order -->
                            <t t-if="o_model == 'account.payment.order'">
                                <t t-if="o.payment_line_ids">
                                    <t t-set="partners" t-value="o.payment_line_ids.mapped('partner_id')"/>
                                    <t t-if="len(partners) == 1">
                                        <t t-set="partner" t-value="partners[0]"/>
                                        <strong>Cliente:</strong><br/>
                                        <div t-esc="partner.name" style="word-break: break-word;"/>
                                        <t t-if="partner.vat"><span>CIF/NIF: </span><span t-esc="partner.vat"/><br/></t>
                                        <t t-if="partner.street"><span t-esc="partner.street"/><br/></t>
                                        <t t-if="partner.zip or partner.city">
                                            <span t-if="partner.zip" t-esc="partner.zip"/> <span t-if="partner.city" t-esc="partner.city"/>
                                        </t>
                                        <t t-if="partner.country_id"><br/><span t-esc="partner.country_id.name"/></t>
                                        <t t-if="partner.phone"><span>Tfno.: </span><span t-esc="partner.phone"/><br/></t>
                                        <t t-if="partner.email"><span>e-mail: </span><span t-esc="partner.email"/><br/></t>
                                    </t>
                                    <t t-elif="len(partners) > 1">
                                        <strong>Clientes:</strong><br/>
                                        <div style="word-break: break-word;">Varios contactos (<t t-esc="len(partners)"/>)</div>
                                    </t>
                                </t>
                            </t>
                            <!-- Caso general: otros modelos con partner_id -->
                            <t t-else="">
                                <t t-if="o.partner_id">
                                    <strong>Cliente:</strong><br/>
                                    <div t-esc="o.partner_id.name" style="word-break: break-word;"/>
                                    <t t-if="o.partner_id.comercial">(<span t-esc="o.partner_id.comercial"/>)<br/></t>
                                    <span>CIF/NIF: </span><t t-esc="o.partner_id.vat"/><br/>
                                    <t t-if="o.partner_id.street"><span t-esc="o.partner_id.street"/><br/></t>
                                    <t t-esc="o.partner_id.zip"/> <t t-esc="o.partner_id.city"/>
                                    <t t-if="o.partner_id.country_id"><br/><t t-esc="o.partner_id.country_id.name"/></t>
                                    <t t-if="o.partner_id.phone"><br/><span>Tfno.: </span><t t-esc="o.partner_id.phone"/></t>
                                    <t t-if="o.partner_id.email"><br/><span>e-mail: </span><t t-esc="o.partner_id.email"/></t>
                                </t>
                            </t>
                        </div>
                    </t>
                </div>

                <!-- Contenido del body -->
<!--                <t t-out="0"/>-->
            </div>
        </xpath>
    </template>
</odoo>