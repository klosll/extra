<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="klo_sale_wizard_form_view" model="ir.ui.view">
        <field name="name">KLO Sale Wizard</field>
        <field name="model">sale.shipment.wizard</field>
        <field name="inherit_id" ref="pways_transportor_management.sale_wizard_form_view"/>
        <field name="arch" type="xml">
                <xpath expr = "//field[@name = 'vehicle']" position="attributes">
                    <attribute name="domain">
                        [('model_id.vehicle_type','!=', 'remolque')]
                    </attribute>
                </xpath>

            <xpath expr = "//field[@name='vehicle']" position="after">
                <field name="remolque_id" domain="[('model_id.vehicle_type','=', 'remolque')]"/>
            </xpath>
        </field>
    </record>
</odoo>