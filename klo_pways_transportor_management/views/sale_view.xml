<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="klo_transport_management_form" model="ir.ui.view">
            <field name="name">klo.sale.order.form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr = "//field[@name = 'vehicle_id']" position="attributes">
                    <attribute name="readonly">
                        False
                    </attribute>
                    <attribute name="domain">
                        [('transporter_id','=', transporter_id), ('model_id.vehicle_type','!=', 'remolque')]
                    </attribute>
                </xpath>

                <xpath expr = "//field[@name = 'vehicle_driver']" position="attributes">
                    <attribute name="readonly">
                        False
                    </attribute>
                </xpath>

                <xpath expr = "//field[@name = 'vehicle_id']" position="after">
                    <field name="remolque_id" domain="[('transporter_id','=', transporter_id), ('model_id.vehicle_type','=', 'remolque')]" attrs="{'readonly': [['state', 'in', ['done']]]}"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>

