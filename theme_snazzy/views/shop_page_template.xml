	<template id="snazzy_products_stock_available" customize_show="True" inherit_id="website_sale.products_item" active="False" name="Show Product Availability" priority="1">
		<xpath expr="//div[hasclass('oe_product_image')]" position="inside">
			<t t-set="combination" t-value="product._get_first_possible_combination()"/>
			<t t-set="combination_info" t-value="product._get_combination_info(combination, add_qty=add_qty or 1, pricelist=pricelist)"/>
			<t t-set="product_variant" t-value="product.env['product.product'].browse(combination_info['product_id'])"/>
			<!-- <t t-set="first_variant" t-value="product.env['product.product'].sudo().browse([product_variant])"/> -->
			<!-- <t t-set="free_qty" t-value="first_variant.with_context(warehouse=website._get_warehouse_available()).free_qty"/> -->
			<t t-set="available_threshold" t-value="product_variant.available_threshold"/>
			<t t-set="virtual_available" t-value="product_variant.virtual_available"/>
			<t t-set="uom_name" t-value="product_variant.uom_name"/>
			<!-- <t t-set="virtual_available_formatted" t-value="product_variant.virtual_available_formatted"/> -->
			<!-- <t t-set="allow_out_of_stock_order" t-value="first_variant.allow_out_of_stock_order"/> -->
			<t t-if="product.type == 'product'">
				<div class="snazzy_product_stock_availability">
					<t t-if="product.inventory_availability">
						<t t-if="product.inventory_availability == 'threshold'">
							<p t-if="virtual_available &lt;= available_threshold" t-attf-class="availability_message_#{product_template} out_stock_message_shop available-stock-badge bg-warning text-center">
								<t t-esc="virtual_available" /> <t t-esc="uom_name" /> available
							</p>
							<p t-if="virtual_available &gt; available_threshold" t-attf-class="availability_message_#{product_template} out_stock_message_shop in-stock-badge bg-success text-center">In stock</p>
						</t>
						<t t-elif="product.inventory_availability == 'always'">
							<t t-if="virtual_available &gt; 0">
								<div t-attf-class="availability_message_#{product_template}">
									<p class="out_stock_message_shop in-stock-badge bg-success text-center"><t t-esc="virtual_available" /> <t t-esc="product.uom_name" /> available</p>
								</div>
							</t>
							<t t-else="">
								<p class="out_stock_message_shop out-stock-badge bg-danger text-center">Out of Stock</p>
							</t>
						</t>
						<t t-else="">
							<t t-if="product.sudo().qty_available &lt; 1">
								<p class="out_stock_message_shop out-stock-badge bg-danger text-center">Out of Stock</p>
							</t>
							<t t-else="">
								<p class="out_stock_message_shop in-stock-badge bg-success text-center">In Stock</p>
							</t>
						</t>
					</t>
					<t t-else="">
                        <t t-if="product.sudo().qty_available &lt; 1">
                            <p class="out_stock_message_shop out-stock-badge bg-danger text-center">Out of Stock</p>
                        </t>
                        <t t-else="">
                            <p class="out_stock_message_shop in-stock-badge bg-success text-center">In Stock</p>
                        </t>
                    </t>
				</div>
			</t>
		</xpath>
   	</template>

