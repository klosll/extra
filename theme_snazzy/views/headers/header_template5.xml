<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="theme_snazzy_header5" inherit_id="website.layout" customize_show="True" name="Header Five" active="False">
        <xpath expr="//header//nav" position="replace">
			<nav data-name="Navbar" id="snazzy-header5" t-attf-class="snazzy_header shadow-sm snazzy_header_five navbar-light o_cc">
				<section class="top-header d-none d-xl-block py-2">
					<div class="container">
						<div class="row align-items-center">
							<div class="col-lg-4 d-none d-lg-block">
								<div class="user-contact">
									<p class="mb-0 pr-2 small">Free Shipping order from all item</p>
								</div>
							</div>
							<div class="header_auto_assignm col-lg-4 d-none d-md-block pr-0 text-center">
								<div class="user-info d-flex justify-content-center">
									<a class="mb-0 btn btn-link py-0 text-decoration-none pr-2"><span class="small">Summer Sale Discount</span></a>
									<a class="mb-0 btn btn-link p-0 text-danger text-decoration-none"><span class="small">Off 30%</span></a>
								</div>
							</div>
							<div class="col-lg-4 d-none d-lg-block">
								<div class="d-flex align-items-center float-right">
									<!-- Language Selector -->
									<t t-call="website.placeholder_header_language_selector">
										<t t-set="_div_classes" t-valuef="my-auto ml-0"/>
									</t>
									<!-- Pricelist Selector -->
									<t t-call="theme_snazzy.placeholder_snazzy_header_pricelist"/>
								</div>
							</div>
						</div>
					</div>
				</section>
                <section class="middle-header py-3">
					<div class="container">
						<div class="row align-items-center">
							<div class="col-lg-3 d-none d-lg-block">
								<div class="d-flex contact-content  align-items-center">
									<i class="ri ri-customer-service-line align-middle mr-2"></i>
									<div class="content-info">
										<p class="title-content m-0 small">1900-8888-1801</p>
										<p class="sub-content m-0">24/7 Support center</p>
									</div>
								</div>
                            </div>
							<div class="col-lg-6 d-flex justify-content-center align-items-center">
								<button type="button" id="show-sidebar" class="mobile-sidebar-toggle mr-4 btn btn-sm btn-dark d-block d-lg-none">
									<span class="ri ri-menu-line"></span>
								</button>
								<div class="snazzy-logo justify-content-md-start mx-auto mx-lg-0 d-flex">
									<t t-call="website.placeholder_header_brand"/>
								</div>
								<t t-call="theme_snazzy.snazzy_header_mobile_cart">
									<t t-set="_class" t-value="'d-block d-lg-none'"/>
								</t>
							</div>
                            <div class="col-lg-3 d-none d-lg-block text-right header_right">
								<div class="wishlist align-middle d-none d-lg-inline-block list-unstyled">
									<t t-call="website_sale_wishlist.header_wishlist_link">
										<t t-set="_icon" t-value="True"/>
										<t t-set="_icon_color" t-value="''"/>
										<t t-set="_item_class" t-value="'nav-item'"/>
										<t t-set="_link_class" t-value="'nav-link'"/>
									</t>
								</div>
								<div class="cart bizople-add-to-cart align-middle d-none d-lg-inline-block list-unstyled" id="">
									<t t-set="website_sale_order" t-value="website.sale_get_order()" />
									<t t-call="website_sale.header_cart_link">
										<t t-set="_icon" t-value="True"/>
										<t t-set="_icon_color" t-value="''"/>
										<t t-set="_item_class" t-value="'nav-item'"/>
										<t t-set="_link_class" t-value="'nav-link show_cart_sidebar'"/>
									</t>
								</div>
								<t t-call="theme_snazzy.theme_snazzy_signin_main_template">
									<t t-set="_myaccount_class" t-value="'align-items-center align-middle d-none d-md-inline-block'"/>
									<t t-set="_icon" t-value="True"/>
									<t t-set="_text" t-value="False"/>
								</t>
							</div>
						</div>
					</div>
				</section>
                <section class="bottom-header py-3 d-none d-lg-block">
					<div class="container">
						<div class="row align-items-center">
							<div class="col-lg-8">
								<div class="d-none d-md-block header-center bottom_content">
									<nav class="navbar navbar-expand-md p-0" id="bizople-header-5">
										<div class="collapse navbar-collapse" id="snazzy-header5">
											<ul class="nav navbar-nav justify-content-center" id="top_menu">
												<t t-foreach="website.menu_id.child_id" t-as="submenu">
													<t t-call="website.submenu">
														<t t-set="item_class" t-value="'nav-item'" />
														<t t-set="link_class" t-value="'nav-link'" />
													</t>
												</t>
											</ul>
										</div>
									</nav>
								</div>
							</div>
							<div class="col-lg-4 d-none d-md-block">
								<div class="search bizople-search">
									<t t-call="theme_snazzy.snazzy_product_searchbar"/>
								</div>
							</div>
						</div>
					</div>
				</section>
				<div class="container">
					<div class="mbl-search-box d-block d-lg-none">
						<t t-call="theme_snazzy.snazzy_product_searchbar">
							<t t-set="searchbar_classes" t-value="'d-block d-lg-none bizople-search mbl-search-bar'"/>
						</t>
					</div>
					<t t-call="theme_snazzy.snazzy_mobile_categories"/>
				</div>
            </nav>
         </xpath>
		 <xpath expr="//header" position="before">
			<div class="d-block d-lg-none">
				<t t-call="theme_snazzy.bizople_mobile_bottom_icon_bar"/>
			</div>
			<nav id="cart_sidebar" class="cart-sidebar bg-white">
				<t t-call="theme_snazzy.cart_sidebar_content"/>
			</nav>
			<div class="cart_sidebar_backdrop"></div>
		</xpath>
    </template>
</odoo>
