<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<template id="theme_common_footer7" inherit_id="website.layout" name="Footer Seven" active="False">
       	<xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" class="oe_structure oe_structure_solo" t-ignore="true" t-if="not no_footer">
                <section id="footer_theme_common7" class="footer_theme_common7 o_footer pt48 pb48">
                    <section class="subscribe-content mb-4">
                        <div class="container">
                            <section class="row bg-white d-flex align-items-center p-3">
                                    <div class="col-md-12 col-lg-8 d-flex align-items-center subscribe-btn flex-wrap">
                                        <div class="title mr-4">Sign Up For Newsletter
                                        </div>
                                        <div class="block-subscribe">
                                            <form class="input-group js_subscribe d-flex" data-list-id="1">
                                                <input type="email" name="email" class="js_subscribe_email form-control bg-white" placeholder="Email Address"/>
                                                <span class="input-group-append">
                                                    <a role="button" href="#" class="btn btn-secondary js_subscribe_btn h-100">Subscribe</a>
                                                    <a role="button" href="#" class="btn btn-success js_subscribed_btn h-100 d-none" disabled="disabled">Thanks</a>
                                                </span>
                                            </form>
                                        </div>
                                    </div>
                                    <div class="col-md-12 col-lg-4 d-flex align-items-center justify-content-end social-share">
                                        <div class="social-icons">
                                            <a class="link" t-att-href="website.social_facebook" t-if="website.social_facebook" target="_blank">
                                                <i class="fa fa-facebook" />
                                            </a>
                                            <a class="link" t-att-href="website.social_twitter" t-if="website.social_twitter" target="_blank">
                                                <i class="fa fa-twitter" />
                                            </a>
                                            <a class="link" t-att-href="website.social_instagram" t-if="website.social_instagram" target="_blank">
                                                <i class="fa fa-instagram"></i>
                                            </a>
                                            <a class="link" t-att-href="website.social_linkedin" t-if="website.social_linkedin" target="_blank">
                                                <i class="fa fa-linkedin" />
                                            </a>
                                        </div>
                                    </div>
                            </section>
                        </div>
                    </section>
                    <section class="top-footer">
                        <div class="container">
                            <div class="row justify-content-cente border-bottom">
                                <div class="col-lg-6 mb-3 mb-lg-0 col-md-12">
                                    <div class="block-footer">
                                        <div class="footer-logo mb-3">
                                            <a href="/" class="navbar-brand logo p-0 m-0">
                                                <img src="/theme_snazzy/static/src/img/snazzy-logo.png" class="img-fluid"/>
                                            </a>
                                        </div>
                                        <div class="content-block-footer">
                                            <ul class="contact-list pl-0">
                                                <li class="address-contact d-flex">
                                                    <p class="m-0"><span class="icon icon-House mr-3"/></p>
                                                    <p class="m-0"><span t-esc="res_company.street"/>,<span t-esc="res_company.city"/>,<span t-esc="res_company.zip"/></p>
                                                </li>
                                                <li class="address-contact d-flex">
                                                    <p class="m-0"><span class="lnr lnr-phone-handset mr-3"/></p>
                                                    <p class="m-0"><span t-esc="res_company.phone"/></p>
                                                </li>
                                                <li class="address-contact d-flex">
                                                    <p class="m-0"><span class="ri ri-mail-send-line mr-3"/></p>
                                                    <p class="m-0"><span t-esc="res_company.email"/></p>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4 mb-3 mb-lg-0 col-lg-2">
                                    <div class="footer-links">
                                        <h6 class="mb-3">Company</h6>
                                        <p><a href="#">About Us</a></p>
                                        <p><a href="#">Contact</a></p>
                                        <p><a href="#">Shipping Return</a></p>
                                        <p><a href="#">FAQ</a></p>
                                    </div>
                                </div>
                                <div class="col-md-4 mb-3 mb-lg-0 col-lg-2">
                                    <div class="footer-links">
                                        <h6 class="mb-3">Information</h6>
                                        <p><a href="#">My Account</a></p>
                                        <p><a href="#">Login</a></p>
                                        <p><a href="#">My Cart</a></p>
                                        <p><a href="#">Wishlist</a></p>
                                        <p><a href="#">Checkout</a></p>
                                    </div>
                                </div>
                                <div class="col-md-4 mb-3 mb-lg-0 col-lg-2">
                                    <div class="footer-links">
                                        <h6 class="mb-3">Contact</h6>
                                        <p><a href="#">Customer Service</a></p>
                                        <p><a href="#">Store Locator</a></p>
                                        <p><a href="#">Wholesale</a></p>
                                        <p><a href="#">Career</a></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                    <section class="bottom-footer">
                        <div class="container">
                            <div class="row align-items-center bottom-content">
                                <div class="col-md-12 col-lg-12 d-flex align-items-center p-lg-0">
                                    <p class="title mr-5 mb-0 py-3">Shop By Brand
                                    </p>
                                    <div class="brand-images">
                                        <img src="/theme_snazzy/static/src/img/footer-brand.png" class="img-fluid"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                </section>
            </div>
        </xpath>
    </template>
</odoo>