<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<template id="theme_common_footer6" inherit_id="website.layout" name="Footer Six" active="False">
       	<xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" class="oe_structure oe_structure_solo" t-ignore="true" t-if="not no_footer">
                <section id="footer_theme_common6" class="footer_theme_common6 o_footer">
                <section class="footer-section pt48 pb32">
                    <div class="container-fluid px-lg-5">
                        <div class="row justify-content-center">
                            <div class="col-md-6 mb-4 mb-lg-0 col-lg-2">
                                <div class="footer-logo">
                                    <a href="/" class="navbar-brand logo p-0 m-0">
                                        <img src="/theme_snazzy/static/src/img/snazzy-logo.png" class="img-fluid"/>
                                    </a>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4 mb-lg-0 col-lg-3">
                                <ul class="contact-list pl-0 py-1 ">
                                    <li class="address-contact d-flex mb-1">
                                        <p class="m-0">T: <span t-esc="res_company.phone"/></p>
                                    </li>
                                    <li class="address-contact d-flex">
                                        <p class="m-0">E: <span t-esc="res_company.email"/></p>
                                    </li>
                                </ul>
                            </div>
                            <div class="col-md-6 mb-4 mb-lg-0 col-lg-2">
                                <div class="footer-links">
                                    <p><a href="#">Customer Service</a></p>
                                    <p><a href="#">Store Locator</a></p>
                                    <p><a href="#">Wholesale</a></p>
                                    <p><a href="#">Career</a></p>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4 mb-lg-0 col-lg-2">
                                <div class="footer-links">
                                    <p><a href="#">Login</a></p>
                                    <p><a href="#">My Cart</a></p>
                                    <p><a href="#">Wishlist</a></p>
                                    <p><a href="#">Checkout</a></p>
                                </div>
                            </div>
                        
                            <div class="col-md-12 mb-4 mb-lg-0 col-lg-3">
                                <div class="block-footer mb-3">
                                    <p class="newsletter-description mb-3">Get on the List So we Can Stay in touch</p>
                                    <div class="block-subscribe-footer">
                                        <form class="input-group js_subscribe mt16" data-list-id="1">
                                            <input type="email" name="email" class="js_subscribe_email form-control bg-white" placeholder="Email Address"/>
                                            <span class="input-group-append">
                                                <a role="button" href="#" class="btn btn-primary js_subscribe_btn h-100">Subscribe</a>
                                                <a role="button" href="#" class="btn btn-success js_subscribed_btn h-100 d-none" disabled="disabled">Thanks</a>
                                            </span>
                                        </form>
                                    </div>
                                </div>
                                <div class="social-icons">
                                    <a class="link" t-att-href="website.social_facebook" t-if="website.social_facebook" target="_blank">
                                        <i class="fa fa-facebook" />
                                    </a>
                                    <a class="link" t-att-href="website.social_twitter" t-if="website.social_twitter" target="_blank">
                                        <i class="fa fa-twitter" />
                                    </a>
                                    <a class="link" t-att-href="website.social_instagram" t-if="website.social_instagram" target="_blank">
                                        <i class="fa fa-instagram"></i>
                                    </a>
                                    <a class="link" t-att-href="website.social_linkedin" t-if="website.social_linkedin" target="_blank">
                                        <i class="fa fa-linkedin" />
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                </section>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('o_footer_copyright')]" position="replace">
			<div t-if="not no_copyright" class="o_footer_copyright footer6_copyright">
				<section class="copyright-section py-4">
                    <div class="container-fluid px-lg-5">
                        <div class="row align-items-center">
                            <div class="col-md-7 mb-4 mb-md-0 footer-langage-option">
                                <p class="m-0 o_footer_copyright_name">All Rights Are Reserved By ©<span t-field="res_company.name" /> 2023</p>
                            </div>
                            <div class="col-md-5">
                                <div class="payment-image text-md-right">
                                    <img src="/theme_snazzy/static/src/img/payment-footer-black.png" class="img-fluid"/>
                                </div>
                            </div>
                        </div>
                    </div>
				</section>
			</div>
		</xpath>
    </template>
</odoo>