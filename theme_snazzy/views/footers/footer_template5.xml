<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<template id="theme_common_footer5" inherit_id="website.layout" name="Footer Five" active="False">
       	<xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" class="oe_structure oe_structure_solo" t-ignore="true" t-if="not no_footer">
                <section id="footer_theme_common5" class="footer_theme_common5 o_footer">
                    <section class="top-footer">
                        <div class="container">
                            <div class="row justify-content-center pt48 pb8 border-bottom">
                                <div class="col-lg-4 mb-3 mb-lg-0 col-md-4">
                                    <div class="block-footer">
                                        <div class="footer-logo mb-2">
                                            <a href="/" class="navbar-brand logo p-0 m-0">
                                                <img src="/theme_snazzy/static/src/img/snazzy-logo-white.png" class="img-fluid"/>
                                            </a>
                                        </div>
                                        <div class="content-block-footer mb-5">
                                        <p class="">Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s.</p>
                                        </div>
                                        <div class="social-share">
                                            <h4 class="mr-5 ">Social Links</h4>
                                            <div class="social-icons">
                                                <a class="link " t-att-href="website.social_facebook" t-if="website.social_facebook" target="_blank">
                                                    <i class="fa fa-facebook" />
                                                </a>
                                                <a class="link " t-att-href="website.social_twitter" t-if="website.social_twitter" target="_blank">
                                                    <i class="fa fa-twitter" />
                                                </a>
                                                <a class="link " t-att-href="website.social_instagram" t-if="website.social_instagram" target="_blank">
                                                    <i class="fa fa-instagram"></i>
                                                </a>
                                                <a class="link " t-att-href="website.social_linkedin" t-if="website.social_linkedin" target="_blank">
                                                    <i class="fa fa-linkedin" />
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-8 mb-3 mb-lg-0 col-md-8">
                                    <div class="row">
                                        <div class="col-md-3 mb-3 mb-lg-0 col-lg-3">
                                            <div class="footer-links">
                                                <h6 class="mb-3 ">Company</h6>
                                                <p><a href="#">About Us</a></p>
                                                <p><a href="#">Contact</a></p>
                                                <p><a href="#">Shipping Return</a></p>
                                                <p><a href="#">FAQ</a></p>
                                            </div>
                                        </div>
                                        <div class="col-md-3 mb-3 mb-lg-0 col-lg-3">
                                            <div class="footer-links">
                                                <h6 class="mb-3 ">Information</h6>
                                                <p><a href="#">My Account</a></p>
                                                <p><a href="#">Login</a></p>
                                                <p><a href="#">My Cart</a></p>
                                                <p><a href="#">Wishlist</a></p>
                                                <p><a href="#">Checkout</a></p>
                                            </div>
                                        </div>
                                        <div class="col-md-3 mb-3 mb-lg-0 col-lg-3">
                                            <div class="footer-links">
                                                <h6 class="mb-3 ">Contact</h6>
                                                <p><a href="#">Customer Service</a></p>
                                                <p><a href="#">Store Locator</a></p>
                                                <p><a href="#">Wholesale</a></p>
                                                <p><a href="#">Career</a></p>
                                            </div>
                                        </div>
                                        <div class="col-md-3 mb-3 mb-lg-0 col-lg-3">
                                            <div class="footer-links">
                                                <h6 class="mb-3 ">Market Place</h6>
                                                <p><a href="#">About Us</a></p>
                                                <p><a href="#">Contact</a></p>
                                                <p><a href="#">Shipping Return</a></p>
                                                <p><a href="#">FAQ</a></p>
                                            </div>
                                        </div>
                                        <div class="col-lg-12  d-flex align-items-center justify-content-between mt8 subscribe-btn py-4 flex-wrap px-2 px-0">
                                            <div class="title mr-4 ">Subcribe for latest upadate and offers.
                                            </div>
                                            <div class="block-subscribe">
                                                <form class="input-group js_subscribe d-flex" data-list-id="1">
                                                    <input type="email" name="email" class="js_subscribe_email form-control bg-white" placeholder="Email Address"/>
                                                    <span class="input-group-append">
                                                        <a role="button" href="#" class="btn btn-secondary js_subscribe_btn h-100"><span class="ri ri-arrow-right-s-line text-secondary"/></a>
                                                        <a role="button" href="#" class="btn btn-success js_subscribed_btn h-100 d-none" disabled="disabled"><span class="ri ri-check-line text-secondary"/></a>
                                                    </span>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                </section>
            </div>
        </xpath>

        <xpath expr="//div[hasclass('o_footer_copyright')]" position="replace">
			<div t-if="not no_copyright" class="o_footer_copyright footer5_copyright">
				<section class="copyright-section py-4">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-md-7 mb-4 mb-md-0 footer-langage-option">
                                <p class="m-0 o_footer_copyright_name ">All Rights Are Reserved By ©<span t-field="res_company.name" /> 2023</p>
                            </div>
                            <div class="col-md-5">
                                <div class="payment-image text-md-right">
                                    <img src="/theme_snazzy/static/src/img/payment-footer-white.png" class="img-fluid"/>
                                </div>
                            </div>
                        </div>
                    </div>
				</section>
			</div>
		</xpath>
    </template>
</odoo>