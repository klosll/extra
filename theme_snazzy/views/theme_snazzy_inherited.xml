	<!-- Heading tags style options -->
	<template id="heading_style_options" inherit_id="website.snippet_options">
		<xpath expr="//div[@data-js='OptionsTab']" position="inside">
			<we-title>Bizople Custom Settings</we-title>
			<we-row string="Product Background Color">
				<we-colorpicker string=""
					class="o_we_sublevel_1"
					data-select-style="true"
					data-customize-website-color="" 
					data-color-type="theme" 
					data-color="product-bgcolor"
					data-css-property="background-color"
					data-color-prefix="bg-"
					data-variable="product-bgcolor"
					/>
			</we-row>

			<we-row string="H1">
				<we-fontfamilypicker data-variable="h1-font" />
				<we-input data-customize-website-variable="null" data-variable="h1-font-size" data-unit="px"
					data-save-unit="rem" />
			</we-row>
			<we-row string="H2">
				<we-fontfamilypicker data-variable="h2-font" />
				<we-input data-customize-website-variable="null" data-variable="h2-font-size" data-unit="px"
					data-save-unit="rem" />
			</we-row>
			<we-row string="H3">
				<we-fontfamilypicker data-variable="h3-font" />
				<we-input data-customize-website-variable="null" data-variable="h3-font-size" data-unit="px"
					data-save-unit="rem" />
			</we-row>
			<we-row string="H4">
				<we-fontfamilypicker data-variable="h4-font" />
				<we-input data-customize-website-variable="null" data-variable="h4-font-size" data-unit="px"
					data-save-unit="rem" />
			</we-row>
			<we-row string="H5">
				<we-fontfamilypicker data-variable="h5-font" />
				<we-input data-customize-website-variable="null" data-variable="h5-font-size" data-unit="px"
					data-save-unit="rem" />
			</we-row>
			<we-row string="H6">
				<we-fontfamilypicker data-variable="h6-font" />
				<we-input data-customize-website-variable="null" data-variable="h6-font-size" data-unit="px"
					data-save-unit="rem" />
			</we-row>
			<div>
				<we-checkbox string="Login Signup Popup option"
                     data-customize-website-views="theme_snazzy.loginsignup_popup_bizt"
                     data-reload="/"/>
        		<we-checkbox string="Show Product Background Color"
                     data-customize-website-views="theme_snazzy.product_background_color"
                     data-reload="/"/>
				<we-checkbox string="Infinite Load"
                     data-customize-website-views="theme_snazzy.snazzy_infinite_load"
                     data-reload="/"/>
				<we-checkbox string="Lazy Load"
                     data-customize-website-views="theme_snazzy.snazzy_lazy_load"
                     data-reload="/"/>
				<we-checkbox string="Reorder"
                     data-customize-website-views="theme_snazzy.snazzy_website_reorder"
                     data-reload="/"/>
				<we-checkbox string="B2B Mode"
                     data-customize-website-views="theme_snazzy.snazzy_b2b_mode"
                     data-reload="/"/>
			</div>
			
		</xpath>
	</template>

