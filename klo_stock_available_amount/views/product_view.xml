<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="klo_view_stock_product_tree" model="ir.ui.view">
            <field name="name">klo.product.stock.tree.inherit</field>
            <field name="model">product.product</field>
            <field name="groups_id" eval="[(4, ref('stock.group_stock_user'))]"/>
            <field name="inherit_id" ref="product.product_product_tree_view"/>
            <field name="arch" type="xml">
                <field name="qty_available" position="after">
                    <field name="qty_available_amount"
                           attrs="{'invisible':[('type', '!=', 'product')]}"
                           optional="show"
                           decoration-danger="virtual_available &lt; 0"
                           decoration-warning="virtual_available == 0"
                           decoration-bf="1"
                    />
                </field>
            </field>
        </record>

        <record id="klo_view_stock_product_template_tree" model="ir.ui.view">
            <field name="name">klo.product.template.stock.tree.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="stock.view_stock_product_template_tree" />
            <field name="arch" type="xml">
                <field name="qty_available" position="after">
                    <field name="qty_available_amount"
                           attrs="{'invisible':[('type', '!=', 'product')]}"
                           optional="show"
                           decoration-danger="virtual_available &lt; 0"
                           decoration-warning="virtual_available == 0"
                           decoration-bf="1"
                    />
                </field>
            </field>
        </record>
    </data>
</odoo>
