<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="make_invisible" model="res.groups">
        <field name="name">Invisible</field>
    </record>
    <record model="ir.ui.menu" id="stock.menu_action_inventory_tree">
        <field name="groups_id" eval="[(6,0,[ref('make_invisible')])]"/>
    </record>

    <record id="view_stock_inventory_filter" model="ir.ui.view">
        <field name="name">stock.inventory.filter</field>
        <field name="model">stock.inventory</field>
        <field name="arch" type="xml">
            <search string="Search Inventory">
                <field name="name" string="Reference"/>
                <field name="inventory_type" string="Inventory Type"/>
                <field name="product_ids" string="Product" filter_domain="['|', ('product_ids', 'ilike', self), ('line_ids.product_id','ilike',self)]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="In Progress" name="confirm" domain="[('state', '=', 'confirm')]"/>
                <filter string="Validated" name="done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Inventory Date" name="inventory_date" date="date"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="status" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Inventory Type" name="inventory_type" domain="[]" context="{'group_by': 'inventory_type'}"/>
                    <filter string="Inventory Date" name="inventories_month" domain="[]" context="{'group_by': 'date'}" help="Physical Inventories by Date"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_stock_inventory_tree" model="ir.ui.view">
        <field name="name">stock.inventory.tree</field>
        <field name="model">stock.inventory</field>
        <field name="arch" type="xml">
            <tree string="Lot/Serial Number Inventory" sample="1">
                <field name="date"/>
                <field name="name"/>
                <field name="inventory_type"/>
                <field name="location_id" optional="hide" groups="stock.group_stock_multi_locations"/>
                <field name="product_ids" widget="many2many_tags" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="state" widget="badge" decoration-success="state == 'done'" decoration-info="state in ('draft', 'confirm')"/>
            </tree>
        </field>
    </record>

    <record id="view_stock_inventory_kanban" model="ir.ui.view">
        <field name="name">stock.inventory.kanban</field>
        <field name="model">stock.inventory</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="name"/>
                <field name="date"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><span><t t-esc="record.name.value"/></span></strong>
                                </div>
                                <field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'cancel': 'default', 'confirm': 'success', 'done': 'success'}}"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="date" widget="date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_stock_inventory_form" model="ir.ui.view">
        <field name="name">stock.inventory.form</field>
        <field name="model">stock.inventory</field>
        <field name="arch" type="xml">
            <form string="Inventory Adjustment">
            <header>
                <button name="action_start" string="Start Inventory" type="object" class="o_highlight" groups="stock.group_stock_user" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                <!-- <button name="action_open_inventory_lines" string="Continue Inventory" type="object" class="o_highlight" groups="stock.group_stock_user" attrs="{'invisible': [('state', '!=', 'confirm')]}"/> -->
                <button name="action_validate" string="Validate Inventory" type="object" groups="stock.group_stock_manager" attrs="{'invisible': ['|', ('state', '!=', 'confirm'), ('line_ids', '!=', False)]}"/>
                <button name="action_validate" string="Validate Inventory" type="object" class="o_highlight" groups="stock.group_stock_manager" attrs="{'invisible': ['|', ('state', '!=', 'confirm'), ('line_ids', '=', False)]}"/>
                <button name="action_print" string="Report" type="object" groups="stock.group_stock_user" attrs="{'invisible': [('state', '=', 'draft')]}"/>
                <button name="action_cancel_draft" string="Set to Draft" type="object" attrs="{'invisible': [('state', '!=', 'cancel')]}"/>
                <button name="action_cancel_draft" string="Cancel Inventory" type="object"
                    confirm="If you cancel this inventory adjustment, all its inventory adjustment lines will be lost. Are you sure you want to discard it ?"
                    attrs="{'invisible': [('state', '!=', 'confirm')]}"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,confirm,done"/>
            </header>

            <sheet>
                <field name="line_ids" invisible="1"/>
                <div class="oe_button_box" name="button_box" attrs="{'invisible': [('state', '=', 'draft')]}">
                    <button name="action_open_inventory_lines" type="object" class="oe_stat_button" icon="fa-building-o">
                        <field name="inventory_line_count" widget="statinfo"/>
                    </button>
                    <button string="Product Moves" type="object"
                            name="action_view_related_move_lines"
                            class="oe_stat_button" icon="fa-exchange"
                            attrs="{'invisible': [('state', '!=', 'done')]}"
                            context="{'no_reference': True}"/>
                </div>

                <div class="o_title">
                    <label for="name" class="o_edit_only"/>
                    <h1>
                        <field name="name" placeholder="e.g. Annual inventory" attrs="{'readonly': [('state', '=', 'done')]}" />
                    </h1>
                </div>

                <group>
                    <group>
                        <field name="password" password="True" attrs="{'invisible': [('state', '!=', 'confirm')]}"/>
                    </group>
                </group>
                <group attrs="{'invisible': [('state', '!=', 'draft')]}">
                    <group>
                        <field name="location_id" options="{'no_create': True}"
                               force_save="1"
                               attrs="{'readonly': [('state', '=', 'done')]}"/>

                        <field name="inventory_type" widget="radio" attrs="{'readonly': [('state', '=', 'done')]}"/>
                        <field name="product_ids"
                               context="{'default_type': 'product'}"
                               invisible="1"
                               attrs="{'readonly': [('state', '=', 'done')]}"
                               widget="many2many_tags"/>
                        
                        <labkel for="import_file"  attrs="{'invisible': [('inventory_type', '!=', 'xls')]}" />
                        <h1  attrs="{'invisible': [('inventory_type', '!=', 'xls')]}"> 
                            <field name="import_filename" invisible="1" />
                            <field name="import_file" filename="import_filename" />
                        </h1>

                        <field name="exhausted" attrs="{'readonly': [('state', '=', 'done')], 'invisible': [('inventory_type', 'in', ['product', 'xls'])]}" />
                        <field name="company_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}" attrs="{'readonly': [('state', '=', 'done')]}" />
                        <field name="date" attrs="{'readonly': [('state', '=', 'done')]}" />
                        <field name="categ_id" attrs="{
                            'invisible': [('inventory_type', '!=', 'categ')],
                            'required': [('inventory_type', '=', 'categ')],
                            'readonly': [('state', '!=', 'draft')]
                        }" />
                        <field name="lot_id" attrs="{
                            'invisible': [('inventory_type', '!=', 'lot')],
                            'required': [('inventory_type', '=', 'lot')],
                            'readonly': [('state', '!=', 'draft')]
                        }" />
                        <field name="product_id" domain="[('type', '=', 'product')]" attrs="{
                            'invisible': [('inventory_type', '!=', 'one')],
                            'required': [('inventory_type', '=', 'one')],
                            'readonly': [('state', '!=', 'draft')]
                        }" />
                        <field name="prefill_counted_quantity" widget="radio" attrs="{'invisible': [('state', '!=', 'draft')]}" />
                    </group>
                </group>
                <notebook attrs="{'invisible': [('state', '=', 'draft')]}">
					<page string="Product">
                        <field name="line_ids" force_save="True" attrs="{'readonly': [('state', '=', 'done')]}">
                            <tree editable="bottom"
                                decoration-danger="product_qty != theoretical_qty"
                                decoration-muted="product_qty == theoretical_qty">
                                <field name="is_editable" attrs="{'column_invisible': True}"/>
                                <field name="state" attrs="{'column_invisible': True}"/>
                                <field name="company_id" readonly="1" optional="hidden"/>
                                <field name="location_id" force_save="True" optional="hidden"/>
                                <field name="product_id" force_save="True"/>
                                <field name="prod_lot_id" force_save="True" optional="hidden"/>
                                <field name="theoretical_qty" force_save="True"/>
                                <field name="product_qty" force_save="True"/>
                                <field name="product_uom_id" optional="hidden"/>
                                <field name="difference_qty" force_save="True"/>
                            </tree>
                        </field>
                    </page>

                    <page string="Summary Difference">
                        <group>
                            <group string="Shortages">
                                <field name="product_list_shortages"  widget="text" />
                            </group>
                            <group string="Surpluses">
                                <field name="product_list_surpluses"  widget="text" />
                            </group>
                        </group>
                    </page>
				</notebook>
            </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_stock_inventory" model="ir.actions.act_window">
        <field name="name">Inventory Adjustments</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">stock.inventory</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="view_id" ref="view_stock_inventory_tree"/>
        <field name="search_view_id" ref="view_stock_inventory_filter"/>
        <field name="help" type="html">
          <p class="o_view_nocontent_barcode_scanner">
            Want to speed up your inventory counts? Try our Barcode app
          </p><p>
            Barcode scanner can be activated via inventory settings.
            Manual inventory adjustments can also be performed and pre-filled with
            suggested counted quantity.
          </p>
        </field>
    </record>

    <record id="model_stock_inventory_line_action_reset_product_qty" model="ir.actions.server">
        <field name="name">Set counted quantities to 0</field>
        <field name="model_id" ref="model_stock_inventory_line"/>
        <field name="binding_model_id" ref="model_stock_inventory_line"/>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_reset_product_qty()
        </field>
    </record>

    <record id="model_stock_inventory_line_action_recompute_quantity" model="ir.actions.server">
        <field name="name">Recompute On Hand Quantity</field>
        <field name="model_id" ref="model_stock_inventory_line"/>
        <field name="binding_model_id" ref="model_stock_inventory_line"/>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_refresh_quantity()
        </field>
    </record>

    <menuitem action="action_stock_inventory"
              name="Inventory Adjustments"
			  id="menu_action_stock_inventory"
			  parent="stock.menu_stock_warehouse_mgmt"
              groups="stock_inventory_adjustment.group_inventory_adjustment"
			  sequence="2"/>
</odoo>
