<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_stock_inventory">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <br/>
                        <h2>Inventory Count Sheet</h2>
                        
                        <!-- New section for additional header fields -->
                        <div>
                            <strong>Inventory Name:</strong> <span t-field="docs.name"/><br/>
                            <strong>Location:</strong> <span t-field="docs.location_id.name"/><br/>
                            <strong>Date:</strong> <span t-field="docs.write_date"/><br/>
                            <strong>Created By:</strong> <span t-field="docs.create_uid.name"/><br/>
                        </div>
                        <br/>

                        <br/>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th><strong>Product</strong></th>
                                    <th groups="stock.group_production_lot"><strong>Lot/Serial Number</strong></th>
                                    <th class="text-right"><strong>On hand Quantity</strong></th>
                                    <th class="text-right"><strong>Counted Quantity</strong></th>
                                    <th class="text-right"><strong>Difference</strong></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="docs.line_ids" t-as="line">
                                    <td><span t-field="line.product_id"/></td>
                                    <td groups="stock.group_production_lot"><span t-field="line.prod_lot_id"/></td>
                                    <td class="text-right"><span t-field="line.theoretical_qty"/> <span t-field="line.product_uom_id" groups="uom.group_uom"/></td>
                                    <td class="text-right"><span t-field="line.product_qty"/> <span t-field="line.product_uom_id" groups="uom.group_uom"/></td>
                                    <td class="text-right"><span t-field="line.difference_qty"/> <span t-field="line.product_uom_id" groups="uom.group_uom"/></td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <!-- Table for difference_qty > 0 -->
                        <br/>
                        <h6>SHORTAGES</h6>
                        <table class="table table-sm" t-if="docs.line_ids.filtered(lambda l: l.difference_qty &gt; 0)">
                            <thead>
                                <tr>
                                    <th><strong>Product</strong></th>
                                    <th groups="stock.group_production_lot"><strong>Lot/Serial Number</strong></th>
                                    <th class="text-right"><strong>Counted Quantity</strong></th>
                                    <th class="text-right"><strong>Difference</strong></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="docs.line_ids.filtered(lambda l: l.difference_qty &gt; 0)" t-as="line">
                                    <td><span t-field="line.product_id"/></td>
                                    <td groups="stock.group_production_lot"><span t-field="line.prod_lot_id"/></td>
                                    <td class="text-right"><span t-field="line.product_qty"/> <span t-field="line.product_uom_id" groups="uom.group_uom"/></td>
                                    <td class="text-right"><span t-field="line.difference_qty"/> <span t-field="line.product_uom_id" groups="uom.group_uom"/></td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <!-- Table for difference_qty < 0 -->
                        <br/>
                        <h6>SURPLUSES</h6>
                        <table class="table table-sm" t-if="docs.line_ids.filtered(lambda l: l.difference_qty &lt; 0)">
                            <thead>
                                <tr>
                                    <th><strong>Product</strong></th>
                                    <th groups="stock.group_production_lot"><strong>Lot/Serial Number</strong></th>
                                    <th class="text-right"><strong>Counted Quantity</strong></th>
                                    <th class="text-right"><strong>Difference</strong></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="docs.line_ids.filtered(lambda l: l.difference_qty &lt; 0)" t-as="line">
                                    <td><span t-field="line.product_id"/></td>
                                    <td groups="stock.group_production_lot"><span t-field="line.prod_lot_id"/></td>
                                    <td class="text-right"><span t-field="line.product_qty"/> <span t-field="line.product_uom_id" groups="uom.group_uom"/></td>
                                    <td class="text-right"><span t-field="line.difference_qty"/> <span t-field="line.product_uom_id" groups="uom.group_uom"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>
