<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="action_report_purchase_order_only_by_packaging" model="ir.actions.report">
        <field name="name">Purchase Order Only By Packaging</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field
      name="report_name"
    >klo_purchase_order_only_packaging_report.report_purchaseorder_only_by_packaging</field>
        <field
      name="report_file"
    >klo_purchase_order_only_packaging_report.report_purchaseorder_only_by_packaging</field>
        <field name="binding_model_id" ref="purchase.model_purchase_order" />
        <field name="binding_type">report</field>
    </record>

    <template id="report_purchaseorder_only_by_packaging">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="package_report" t-value="True" />
                <t
          t-call="klo_purchase_order_only_packaging_report.report_purchaseorder_only_by_packaging_document"
          t-lang="o.partner_id.lang"
        />
            </t>
        </t>
    </template>

    <template
            id="report_purchaseorder_only_by_packaging_document"
            inherit_id="purchase.report_purchaseorder_document"
            primary="True"
    >
        <th name="th_taxes" position="attributes">
            <attribute name="style">display:none;</attribute>
        </th>
        <td name="td_taxes" position="attributes">
            <attribute name="style">display:none;</attribute>
        </td>
        <th name="th_date_req" position="attributes">
            <attribute name="style">display:none;</attribute>
        </th>
        <th name="th_quantity" position="attributes">
            <attribute name="style">display:none;</attribute>
        </th>
        <th name="th_price_unit" position="attributes">
            <attribute name="style">display:none;</attribute>
        </th>
        <th name="th_amount" position="attributes">
            <attribute name="style">display:none;</attribute>
        </th>
        <th name="th_discount" position="attributes">
            <attribute name="style">display:none;</attribute>
        </th>

        <xpath expr="//tbody//td[5]" position="attributes">
            <attribute name="style">display:none;</attribute>
        </xpath>
        <xpath expr="//tbody//td[6]" position="attributes">
            <attribute name="style">display:none;</attribute>
        </xpath>
        <xpath expr="//tbody//td[7]" position="attributes">
            <attribute name="style">display:none;</attribute>
        </xpath>
        <xpath expr="//tbody//td[8]/span" position="attributes">
            <attribute name="style">display:none;</attribute>
        </xpath>
        <xpath expr="//tbody//td[9]/span" position="attributes">
            <attribute name="style">display:none;</attribute>
        </xpath>

        <xpath expr="//div[@id='total']" position="attributes">
            <attribute name="style">display:none;</attribute>
        </xpath>

    </template>
</odoo>
