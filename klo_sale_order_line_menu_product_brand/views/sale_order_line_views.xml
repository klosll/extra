<odoo>
    <record id="klo_sale_order_line_tree_product_brand" model="ir.ui.view">
        <field name="name">klo.sale.order.line.tree.product.brand</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale_order_line_menu.sale_order_line_tree" />
        <field name="mode">extension</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <!-- KLO Marca de producto-->
                <field name="product_brand_id" optional="show" />
            </xpath>
        </field>
    </record>
</odoo>
