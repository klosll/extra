<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="invoice_report_dot_matrix_document"
            inherit_id="account.report_invoice_document"
            primary="True"
  >

    <xpath expr="//t[@t-set='o'][@t-value='o.with_context(lang=lang)']" position="before">
        <style>
            /* Forzar 8px en todo el documento */
            body, body * {
                font-size: 10px !important;
            }

            /* Ajustar padding para compensar el tamaño reducido */
            .table th, .table td {
                padding: 1px;
            }

            /* Títulos proporcionales */
            h1 { font-size: 12px !important; }
            h2 { font-size: 10px !important; }
            h3 { font-size: 9px !important; }

            /* Mejorar legibilidad con fuente monoespaciada */
            body {
                font-family: 'Courier New', monospace;
                line-height: 1.2;
            }
        </style>
    </xpath>

