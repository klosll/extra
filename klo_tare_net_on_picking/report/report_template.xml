<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <!-- KLO. Plantilla base de external layout Boxed sin cabecera. Es primary, no modifica la padre -->
        <template id="external_layout_boxed_sin_cabecera" inherit_id="web.external_layout_boxed" primary="True">
            <!-- KLO. Quitamos todos los datos de la cabecera y pie -->
            <xpath expr="//div[@t-attf-class='header o_company_#{company.id}_layout']" position="replace">
            </xpath>
        </template>

        <!-- Llamada previa a el external layout Boxed sin cabecera para declarar company. Si no, da error
        Este Id es el que se llama desde los QWeb -->
        <template id="external_layout_sin_cabecera">
            <t t-if="not o" t-set="o" t-value="doc"/>
            <t t-if="not company">
                <t t-if="company_id">
                    <t t-set="company" t-value="company_id"/>
                </t>
                <t t-elif="o and 'company_id' in o and o.company_id.sudo()">
                    <t t-set="company" t-value="o.company_id.sudo()"/>
                </t>
                <t t-else="else">
                    <t t-set="company" t-value="res_company"/>
                </t>
            </t>
            <t t-call="klo_tare_net_on_picking.external_layout_boxed_sin_cabecera"><t t-raw="0"/></t>
        </template>
</odoo>