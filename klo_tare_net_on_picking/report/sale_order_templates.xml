            </div>
        </div>

    </t>
</template>


<template id="report_saleorder_ticket">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
            <t t-call="klo_tare_net_on_picking.report_saleorder_ticket_document" t-lang="doc.partner_id.lang"/>
        </t>
    </t>
</template>

</odoo>
