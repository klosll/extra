<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="report_saleorder_ticket_document">
    <t t-call="klo_tare_net_on_picking.external_layout_sin_cabecera">
        <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)" />
        <t t-set="forced_vat" t-value="doc.fiscal_position_id.foreign_vat"/> <!-- So that it appears in the footer of the report instead of the company VAT if it's set -->
        <t t-set="company" t-value="doc.company_id"/>

        <!-- KLO. HOJA DE LA IZQUIERDA -->
        <div class="page" style="width:48%; display: inline-block; vertical-align:top; font-size:13px;" align="left">
            <div class="oe_structure"/>

            <div class="mt-4" style="width:68%; display: inline-block; vertical-align:top;" align="left">
                <h2>Ticket de báscula de Salida
                </h2>
            </div>
            <!-- KLO. logo -->
            <div id="company_logo" class="col-3 mb4" style="width:28%; display: inline-block; vertical-align:top;" align="center">
                <div class="col-3 mb4">
                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-height: 55px;" alt="Logo"/>
                </div>
            </div>

            <div id="company_info" style="width:48%; display: inline-block; vertical-align:top;" align="left">
                <ul class="list-unstyled">
                    <li t-if="company.is_company_details_empty"><t t-esc="company.partner_id" t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": true}'/></li>
                    <li t-else="">
                        <t t-esc="company.company_details"/>
                    </li>
                    <li t-if="forced_vat">
                        <t t-esc="company.country_id.vat_label or 'Tax ID'"/>:
                        <span t-esc="forced_vat"/>
                    </li>
                </ul>
            </div>

            <div id="informations"  style="width:48%; display: inline-block; vertical-align:top;" align="left">
                <div>
                    Número: <span t-field="doc.name"/>
                    <br/>
                    <div t-if="doc.state in ['purchase','done'] and doc.date_approve">
                        Fecha/Hora: <span t-field="doc.date_approve"/>
                    </div>
                    <div t-elif="doc.date_order">
                        Fecha/Hora: <span t-field="doc.date_order"/>
                    </div>
                    Nº Carnet Fitosanitarios: 654654213-HML
                </div>
            </div>

            <div id="partner_info" style="width:100%; vertical-align:top; border-box: 25px; padding: 10px; border: 1px solid;" align="left">
                <strong>Cliente:</strong>
                <span t-field="doc.partner_id"
                      t-options='{"widget": "contact", "fields": ["address", "name", "vat"], "no_marker": True}'
                />
                <br/>
            </div>

            <!-- Is there a discount on at least one line? -->
            <t t-set="lines_to_report" t-value="doc._get_order_lines_to_report()"/>

            <table class="table table-sm o_main_table table-borderless mt-4">
                <!-- In case we want to repeat the header, remove "display: table-row-group" -->
                <thead style="display: table-row-group">
                    <tr>
                        <th name="th_description" class="text-start">Producto</th>
                        <th name="th_brut" class="text-end">Bruto (Kg)</th>
                        <th name="th_tare" class="text-end">Tara (Kg)</th>
                        <th name="th_net" class="text-end">Neto (Kg)</th>
                    </tr>
                </thead>
                <tbody class="sale_tbody">

                    <t t-set="current_subtotal" t-value="0"/>

                    <t t-foreach="lines_to_report" t-as="line">

                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                        <tr t-att-class="'bg-200 fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">
                            <t t-if="not line.display_type">
                                <td name="td_name"><span t-field="line.name"/></td>
                            </t>
                            <t t-elif="line.display_type == 'line_section'">
                                <td name="td_section_line" colspan="99">
                                    <span t-field="line.name"/>
                                </td>
                                <t t-set="current_section" t-value="line"/>
                                <t t-set="current_subtotal" t-value="0"/>
                            </t>
                            <t t-elif="line.display_type == 'line_note'">
                                <td name="td_note_line" colspan="99">
                                    <span t-field="line.name"/>
                                </td>
                            </t>
                            <td name="td_brut" class="text-end">
                                <span t-field="line.gross_weight"/>
                            </td>
                            <td name="td_tare" class="text-end">
                                <span t-field="line.tare_weight"/>
                            </td>
                            <td name="td_net" class="text-end">
                                <span t-field="line.net_weight"/>
                            </td>
                        </tr>

                        <t t-if="current_section and (line_last or doc.order_line[line_index+1].display_type == 'line_section') and not line.is_downpayment">
                            <tr class="is-subtotal text-end">
                                <td name="td_section_subtotal" colspan="99">
                                    <strong class="mr16">Subtotal</strong>
                                    <span
                                        t-out="current_subtotal"
                                        t-options='{"widget": "monetary", "display_currency": doc.pricelist_id.currency_id}'
                                    />
                                </td>
                            </tr>
                        </t>
                    </t>
                </tbody>

                <!-- KLO. Pone la lista de lotes y el peso de estos -->
                <thead style="display: table-row-group">
                    <tr>
                        <th name="th_lot" class="text-end"> </th>
                        <th name="th_lot" class="text-end"> </th>
                        <th name="th_lot" class="text-end">Lote</th>
                        <th name="th_net" class="text-end">Neto (Kg)</th>
                    </tr>
                </thead>

                <div class="lots" name="so_lots">
                    <t t-foreach="line.move_ids.move_line_ids" t-as="lot_line">
                        <tr>
                            <td name="td_vacio1" class="text-end">
                            </td>
                            <td name="td_vacio2" class="text-end">
                            </td>
                            <td name="td_lot" class="text-end">
                                <span t-field="lot_line.lot_id.name"/>
                            </td>
                            <td name="td_quantity" class="text-end">
                                <span t-field="lot_line.qty_done"/>
                            </td>
                        </tr>
                    </t>
                </div>

            </table>

            <!-- KLO. Bloque que pone los datos del transporte -->
            <table class="table table-sm o_main_table table-borderless mt-4">
                <!-- In case we want to repeat the header, remove "display: table-row-group" -->
                <thead style="display: table-row-group">
                    <tr>
                        <th name="th_transporter" class="text-end">Transportista</th>
                        <th name="th_license_plate" class="text-end">Matrícula</th>
                        <th name="th_trailer" class="text-end">Remolque</th>
                        <th name="th_driver" class="text-end">Chofer</th>
                    </tr>
                </thead>

                <div class="transport" name="so_transporte">
                    <tr>
                        <td name="td_transporter" class="text-end">
                            <span t-field="doc.transporter_id"/>
                        </td>
                        <td name="td_license_plate" class="text-end">
                            <span t-field="doc.vehicle_id.license_plate"/>
                        </td>
                        <td name="td_trailer" class="text-end">
                            <span t-field="doc.remolque_id.license_plate"/>
                        </td>
                        <td name="td_driver" class="text-end">
                            <span t-field="doc.vehicle_driver"/>
                            <br/>
                            <span t-field="doc.vehicle_driver.licence_id"/>
                        </td>
                    </tr>
                </div>
            </table>

            <!-- KLO. Bloque donde ponemos las firmas -->
            <table class="table table-sm o_main_table table-borderless mt-4">
                <thead style="display: table-row-group">
                    <tr>
                        <th name="th_transporter_sign" class="text-end">El transportista</th>
                        <th name="th_manager_sign" class="text-end">El encargado</th>
                        <th name="th_partner_sign" class="text-end">El cliente</th>
                    </tr>
                </thead>

                <div class="transport_sign" name="so_transporte_firma">
                    <tr style="height:20mm">
                        <td name="td_transporter_sign" class="text-end">
                        </td>
                        <td name="td_manager_sign" class="text-end">
                        </td>
                        <td name="td_partner_sign" class="text-end">
                        </td>
                    </tr>
                </div>
            </table>

            <div t-if="doc.signature" class="mt-4 ml64 mr4" name="signature">
                <div class="offset-8">
                    <strong>Signature</strong>
                </div>
                <div class="offset-8">
                    <img t-att-src="image_data_uri(doc.signature)" style="max-height: 4cm; max-width: 8cm;"/>
                </div>
                <div class="offset-8 text-center">
                    <p t-field="doc.signed_by"/>
                </div>
            </div>

            <div>
                <p t-field="doc.note" name="order_note"/>
                <p t-if="not is_html_empty(doc.payment_term_id.note)">
                    <span t-field="doc.payment_term_id.note"/>
                </p>
                <p t-if="doc.fiscal_position_id and not is_html_empty(doc.fiscal_position_id.sudo().note)"
                    id="fiscal_position_remark">
                    <strong>Fiscal Position Remark:</strong>
                    <span t-field="doc.fiscal_position_id.sudo().note"/>
                </p>
            </div>
        </div>

        <!-- KLO. Se pone un espacio entre las dos hojas para poder hacer el corte.-->
        <div style="width:10mm; display: inline-block;"/>

        <!-- KLO. HOJA DE LA DERECHA -->
        <div class="page" style="width:48%; display: inline-block; vertical-align:top; font-size:13px;" align="left">
            <div class="oe_structure"/>

            <div class="mt-4" style="width:68%; display: inline-block; vertical-align:top;" align="left">
