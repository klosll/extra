                    </div>
                    <div t-elif="doc.date_order">
                        Fecha/Hora: <span t-field="doc.date_order"/>
                    </div>
                    Nº Carnet Fitosanitarios: 654654213-HML
                </div>
            </div>

            <div id="partner_info" style="width:100%; vertical-align:top; border-box: 25px; padding: 10px; border: 1px solid;" align="left">
                <strong>Cliente:</strong>
                <span t-field="doc.partner_id"
