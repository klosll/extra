                    <thead style="display: table-row-group">
                        <tr>
                            <th name="th_observaciones">
                                <span>Observaciones:</span>
                            </th>
                            <th name="th_firma">
                                <span>Conforme:</span>
                            </th>
                        </tr>
                    </thead>
                </table>
            </table>

            <div class="oe_structure"/>
        </div>

    </t>
</template>

<template id="report_ticket_purchaseorder">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-call="klo_tare_net_on_picking.report_ticket_purchaseorder_document" t-lang="o.partner_id.lang"/>
        </t>
    </t>
</template>
</odoo>
