<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="klo_purchase_order_form_inherit" model="ir.ui.view">
        <field name="name">klo.purchase.order.form.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- KLO. Ponemos obligatoria la Campaña, que es el Año Fiscal en la cabecera -->
            <field name="date_order" position="before">
                <field name="fiscal_year_id" attrs="{'readonly': [('state', '=', 'done')], 'required': True}"/>
            </field>
            <!-- KLO. Ponemos los campos de Tara, Neto, etc. para los cálculos del limpio -->
            <!-- KLO
            <field name="partner_ref" position="after">
                <field name="tare_weight" attrs="{'readonly': [('state', '=', 'done')]}"/>
            </field>
            -->

            <!-- KLO. Peso bruto en líneas de Operaciones -->
            <field name="qty_received" position="before">
                <field name="gross_weight" readonly="0" optional="show"/>
                <field name="tare_weight"  readonly="0" optional="show"/>
                <field name="net_weight" editable="0" optional="show"/>
                <field name="specific_weight" readonly="0" optional="show"/>
                <field name="humidity" readonly="0" optional="show"/>
                <field name="deduction" readonly="0" optional="show"/>
            </field>
        </field>
    </record>
</odoo>
