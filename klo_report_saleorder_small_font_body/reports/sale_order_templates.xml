<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="klo_saleorder_report_small_font_body" inherit_id="sale.report_saleorder_document">

    <xpath expr="//t[@t-set='doc'][@t-value='doc.with_context(lang=doc.partner_id.lang)']" position="before">
        <t t-set="font_size" t-value="request.env['ir.config_parameter'].sudo().get_param('klo.saleorder_report_small_font_body', '10')"/>
        <style>
            /* Forzar tamaño dinámico en todo el documento */
            body, body * {
                font-size: <t t-esc="font_size"/>px !important;
            }

            /* Ajustar padding para compensar el tamaño reducido */
            .table th, .table td {
                padding: 1px;
            }

            /* Títulos proporcionales */
            h1 { font-size: <t t-esc="int(font_size) * 1.5"/>px !important; }
            h2 { font-size: <t t-esc="int(font_size) * 1.25"/>px !important; }
            h3 { font-size: <t t-esc="int(font_size) * 1.125"/>px !important; }

            /* Mejorar legibilidad con fuente monoespaciada */
            body {
                font-family: 'Courier New', monospace;
                line-height: 1.2;
            }

            /* Tamaño específico para el título del documento */
            .document-title, .document-title * {
                font-size: <t t-esc="int(font_size) * 1.5"/>px !important;
            }
        </style>
    </xpath>

    <!-- Añade atributo inline al campo que imprime el nombre/número del pedido para que sea más grande -->
    <xpath expr="//t[@t-set='layout_document_title']" position="replace">
        <t t-set="layout_document_title">
            <div class="document-title">
                <span t-if="is_proforma">Pro-Forma Invoice # </span>
                <span t-elif="doc.state in ['draft','sent']">Quotation # </span>
                <span t-else="">Order # </span>
                <span t-field="doc.name">SO0000</span>
            </div>
        </t>
    </xpath>

  </template>
</odoo>
