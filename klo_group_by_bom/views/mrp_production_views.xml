<?xml version="1.0" encoding="utf-8"?>
<!-- KLO - Agrupar por Lista de Materiales -->
<odoo>
    <data>
        <!-- Heredar la vista de búsqueda de Órdenes de Fabricación para añadir
             la opción "Lista de materiales" en el grupo de agrupaciones -->
        <record id="view_mrp_production_filter_bom" model="ir.ui.view">
            <field name="name">mrp.production.filter.bom.inherit</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="mrp.view_mrp_production_filter"/>
            <field name="arch" type="xml">
                <!-- Añadir la opción "Lista de materiales" antes de "Product" en el grupo Group By -->
                <xpath expr="//filter[@name='product']" position="before">
                    <filter string="Lista de materiales" name="bom" domain="[]" context="{'group_by': 'bom_id'}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

