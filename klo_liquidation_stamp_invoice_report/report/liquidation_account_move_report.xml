<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="klo_report_account_move_liquidation" inherit_id="batch_liquidation_report.report_account_move_liquidation">
        <xpath expr="//div[@id='sign']/div[@name='sign']/strong[text()='P.P']" position="after">
            <div class="mt-3" t-if="o.company_id.liquidation_stamp">
                <img t-att-src="image_data_uri(o.company_id.liquidation_stamp)" style="max-height: 100px;" alt="Liquidation Stamp"/>
            </div>
        </xpath>
    </template>
</odoo>
