<odoo>

    <record id="klo_view_move_line_tree" model="ir.ui.view">
        <field name="name">klo.stock.move.line.tree</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree" />
        <field name="arch" type="xml">
            <field name="reference" position="after">
                <field name="picking_id" string="Albarán" optional="show"/>
            </field>
        </field>
    </record>

    <record id="klo_view_move_line_form" model="ir.ui.view">
        <field name="name">klo.stock.move.line.form</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_form" />
        <field name="arch" type="xml">
            <field name="reference" position="after">
                <field name="picking_id" />
            </field>
        </field>
    </record>

</odoo>
