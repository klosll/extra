<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="klo_view_picking_form_kaleidotrans" model="ir.ui.view">
        <field name="name">klo.stock.picking.form.kaleidotrans</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='note']" position="after">
                <page string="KaleidoTrans" name="kaleidotrans">
                    <group col="3">
                        <button name="action_send_kaleidotrans" string="Enviar" type="object"/>
                        <field name="servicio_id" readonly="1"/>
                    </group>
                    <group string="Mensajes KaleidoTrans">
                        <field name="note_kaleidotrans" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
