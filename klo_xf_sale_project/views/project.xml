<odoo>
    <!-- List View-->
    <record id="klo_xf_view_project" model="ir.ui.view">
        <field name="name">klo.xf.project.status.tree</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project" />
        <field name="type">tree</field>
        <field name="field_parent">child_ids</field>
        <field name="arch" type="xml">
            <!-- KLO. Primero, como cambiamos de sitio la columna Elemento del pedido de venta para
            ponerla a la derecha de Pedido, la quitamos primero de donde está puesta -->
            <xpath expr="//field[@name='sale_line_id']" position="replace">
            </xpath>
            <!-- KLO. Ponemos otra columna en la que dice si tiene asignada pedido o factura -->
            <xpath expr="//field[@name='name']" position="before">
                <field name="sale_order_ids" string="Pedidos" widget="many2many_tags" optional="show"/>
                <field name="sale_line_id" optional="show" readonly="1"/>
                <field name="invoice_ids" widget="many2many_tags" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
