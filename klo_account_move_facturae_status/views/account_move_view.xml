<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista lista: columna opcional solo lectura -->
    <record id="view_invoice_tree_facturae_status" model="ir.ui.view">
        <field name="name">account.move.list.facturae.status</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="move_sent_values" position="after">
                <field name="is_facturae_generated"
                       string="Facturae"
                       widget="boolean_toggle"
                       readonly="1"
                       optional="show"/>
            </field>
        </field>
    </record>

    <!-- Vista formulario: campo editable en el apartado Factura-e -->
    <record id="view_move_form_facturae_status" model="ir.ui.view">
        <field name="name">account.move.form.facturae.status</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_es_edi_facturae.view_move_form"/>
        <field name="arch" type="xml">
            <field name="l10n_es_payment_means" position="after">
                <field name="is_facturae_generated"
                       string="Facturae generada"
                       readonly="0"
                />
            </field>
        </field>
    </record>
</odoo>

