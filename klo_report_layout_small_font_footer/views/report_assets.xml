<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="klo_minimal_layout_small_font_footer" inherit_id="web.minimal_layout">
        <xpath expr="//head" position="inside">
            <t t-set="footer_font_size" t-value="request.env['ir.config_parameter'].sudo().get_param('klo.report_layout_small_font_footer', '8')"/>
            <style>
                .o_footer_content {
                    font-size: <t t-out="footer_font_size"/>px !important;
                }
            </style>
        </xpath>
    </template>
</odoo>
