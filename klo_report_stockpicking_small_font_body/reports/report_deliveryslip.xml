<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="klo_report_delivery_document_small_font_body" inherit_id="stock.report_delivery_document">

    <xpath expr="//t[@t-set='o'][@t-value='o.with_context(lang=o._get_report_lang())']" position="before">
        <t t-set="font_size" t-value="request.env['ir.config_parameter'].sudo().get_param('klo.stockpicking_report_small_font_body', '10')"/>
        <style>
            /* Forzar tamaño dinámico en todo el documento */
            body, body * {
                font-size: <t t-esc="font_size"/>px !important;
            }

            /* Ajustar padding para compensar el tamaño reducido */
            .table th, .table td {
                padding: 1px;
            }

            /* Títulos proporcionales */
            h1 { font-size: <t t-esc="int(font_size) * 1.5"/>px !important; }
            h2 { font-size: <t t-esc="int(font_size) * 1.25"/>px !important; }
            h3 { font-size: <t t-esc="int(font_size) * 1.125"/>px !important; }

            /* Mejorar legibilidad con fuente monoespaciada */
            body {
                font-family: 'Courier New', monospace;
                line-height: 1.2;
            }

            /* Tamaño específico para el título del documento */
            .document-title, .document-title * {
                font-size: <t t-esc="int(font_size) * 1.5"/>px !important;
            }
        </style>
    </xpath>

    <!-- Añade atributo inline al campo que imprime el nombre/número de la entrega para que sea más grande -->
    <xpath expr="//h2" position="replace">
        <div class="document-title">
            <span t-field="o.name">WH/OUT/0001</span>
        </div>
    </xpath>

  </template>
</odoo>
