<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="klo_report_invoice_document_price_by_packaging" inherit_id="account.report_invoice_document">
        <th name="th_quantity" position="before">
            <th name="th_boxes_packages_description" t-if="o.move_type == 'out_invoice'">
                <span>Packages description</span>
            </th>
            <th name="th_boxes_packages_price" t-if="o.move_type == 'out_invoice'">
                <span>Packages price</span>
            </th>
        </th>
        <xpath expr="//span[@t-field='line.quantity']/.." position="before">
            <!-- KLO Descripción y precio del empaquetado -->
            <td name="td_boxes_packages_description" t-if="o.move_type == 'out_invoice'" class="text-left">
                <span t-field="line.sale_line_ids.product_packaging_id"/>
            </td>
            <td name="td_boxes_packages_price" t-if="o.move_type == 'out_invoice'" class="text-center">
                <span t-field="line.product_packaging_price" t-options='{"widget": "monetary"}'/>
            </td>
        </xpath>
    </template>
</odoo>
