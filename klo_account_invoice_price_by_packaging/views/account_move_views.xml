<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="klo_view_move_form_price_by_packaging" model="ir.ui.view">
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_packaging_qty']" position="after">
                <field name="product_packaging_price"
                       groups="product.group_stock_packaging"
                       optional="show"
                       readonly="1"
                />
            </xpath>
        </field>
    </record>
</odoo>
