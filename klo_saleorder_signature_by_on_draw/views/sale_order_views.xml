<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Heredamos de la vista del módulo OCA sale_order_digitized_signature
        que es quien añade el field customer_signature (widget="signature")
        después del campo note en la página "Order Lines".
        Insertamos signed_by y signed_on justo ANTES del label y field customer_signature,
        alineados a la izquierda.
    -->
    <record id="view_order_form_signature_by_on" model="ir.ui.view">
        <field name="name">sale.order.form.klo.signature.by.on</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_order_digitized_signature.view_order_form_signature"/>
        <field name="arch" type="xml">
            <xpath expr="//label[@for='customer_signature']" position="before">
                <div style="display: flex; flex-direction: column; align-items: flex-start; margin-bottom: 8px;">
                    <div style="display: flex; align-items: center; margin-bottom: 4px;">
                        <label for="signed_by" string="Firmado por" style="min-width: 140px; font-weight: bold; margin-right: 8px;"/>
                        <field name="signed_by" nolabel="1" style="min-width: 280px;"/>
                    </div>
                    <div style="display: flex; align-items: center;">
                        <label for="signed_on" string="Firmado el" style="min-width: 140px; font-weight: bold; margin-right: 8px;"/>
                        <field name="signed_on" nolabel="1" style="min-width: 180px;"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>

