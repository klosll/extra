<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="klo_lot_expiration_date_report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//t[@t-set='lot_values']" position="replace">
            <t t-set="lot_values" t-value="o._get_invoiced_lot_values_expiration_date()"/>
        </xpath>

        <xpath expr="//t[@t-if='lot_values']" position="replace">
            <t t-if="lot_values">
                <br/>
                <table class="table table-sm" style="width: 60%;" name="invoice_snln_table">
                    <thead>
                        <tr>
                            <th><span>Product</span></th>
                            <th class="text-end"><span>Quantity</span></th>
                                <!-- KLO Quitamos la columna del lote para La Majadilla -->
<!--                            <th class="text-end"><span>Lot</span></th>-->
                            <th class="text-end"><span>FCP / LOTE</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="lot_values" t-as="snln_line">
                            <tr>
                                <td><t t-esc="snln_line['product_name']"/></td>
                                <td class="text-end">
                                    <t t-esc="snln_line['quantity']"/>
                                    <t t-esc="snln_line['uom_name']" groups="uom.group_uom"/>
                                </td>
                                    <!-- KLO Quitamos la columna del lote para La Majadilla -->
<!--                                <td class="text-end"><t t-esc="snln_line['lot_name']"/></td>-->
                                <td><t t-esc="snln_line['lot_expiration_date']" t-options='{"widget": "date"}'/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </t>
        </xpath>
    </template>
</odoo>
