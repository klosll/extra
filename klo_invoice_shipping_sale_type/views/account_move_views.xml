<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Extend Invoice Tree View to add Shipping Sale Type Column -->
        <record id="view_invoice_tree_shipping_sale_type" model="ir.ui.view">
            <field name="name">account.move.tree.shipping.sale.type</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
                <!-- Add the new column after the partner_id field -->
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="shipping_sale_type" string="Tipo pedido dir entrega" optional="hide"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>

