<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="klo_account_payment_line_tree" model="ir.ui.view">
        <field name="name">klo.account.payment.line.tree</field>
        <field name="model">account.payment.line</field>
        <field name="inherit_id" ref="account_payment_order.account_payment_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_currency']" position="attributes">
                <attribute name="sum">Total amount currency</attribute>
            </xpath>
        </field>
    </record>
</odoo>
