<odoo>
    <record id="view_whatsapp_ai_usage_tree" model="ir.ui.view">
        <field name="name">klo.whatsapp.ai.usage.tree</field>
        <field name="model">klo.whatsapp.ai.usage</field>
        <field name="arch" type="xml">
            <list string="Uso de IA (OpenAI)">
                <field name="create_date" string="Fecha"/>
                <field name="session_id"/>
                <field name="model_name"/>
                <field name="prompt_tokens"/>
                <field name="completion_tokens"/>
                <field name="total_tokens" sum="Total tokens"/>
                <field name="estimated_cost_eur" string="Coste est. (€)" sum="Coste total est."/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_ai_usage_search" model="ir.ui.view">
        <field name="name">klo.whatsapp.ai.usage.search</field>
        <field name="model">klo.whatsapp.ai.usage</field>
        <field name="arch" type="xml">
            <search string="Uso de IA">
                <field name="session_id"/>
                <field name="model_name"/>
                <filter string="Hoy" name="today"
                        domain="[('create_date','&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="Este mes" name="this_month"
                        domain="[('create_date','&gt;=', context_today().replace(day=1).strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Modelo IA" name="group_model" context="{'group_by': 'model_name'}"/>
                    <filter string="Sesión" name="group_session" context="{'group_by': 'session_id'}"/>
                    <filter string="Fecha" name="group_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_whatsapp_ai_usage" model="ir.actions.act_window">
        <field name="name">Uso de IA (OpenAI)</field>
        <field name="res_model">klo.whatsapp.ai.usage</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_whatsapp_ai_usage_search"/>
        <field name="context">{'search_default_this_month': 1}</field>
    </record>
</odoo>
