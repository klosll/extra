<odoo>
    <record id="group_whatsapp_order_manager" model="res.groups">
        <field name="name">WhatsApp Order: Gestor</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_wa_session_manager_only" model="ir.rule">
        <field name="name">WhatsApp Session: solo gestores</field>
        <field name="model_id" ref="model_klo_whatsapp_session"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('id', '=', False)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_wa_session_manager_all" model="ir.rule">
        <field name="name">WhatsApp Session: gestores ven todo</field>
        <field name="model_id" ref="model_klo_whatsapp_session"/>
        <field name="groups" eval="[(4, ref('klo_whatsapp_order.group_whatsapp_order_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_wa_message_manager_only" model="ir.rule">
        <field name="name">WhatsApp Message: solo gestores</field>
        <field name="model_id" ref="model_klo_whatsapp_message"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('id', '=', False)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_wa_message_manager_all" model="ir.rule">
        <field name="name">WhatsApp Message: gestores ven todo</field>
        <field name="model_id" ref="model_klo_whatsapp_message"/>
        <field name="groups" eval="[(4, ref('klo_whatsapp_order.group_whatsapp_order_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_wa_ai_usage_manager_only" model="ir.rule">
        <field name="name">WhatsApp AI Usage: solo gestores</field>
        <field name="model_id" ref="model_klo_whatsapp_ai_usage"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('id', '=', False)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_wa_ai_usage_manager_all" model="ir.rule">
        <field name="name">WhatsApp AI Usage: gestores ven todo</field>
        <field name="model_id" ref="model_klo_whatsapp_ai_usage"/>
        <field name="groups" eval="[(4, ref('klo_whatsapp_order.group_whatsapp_order_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
